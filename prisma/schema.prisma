// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id        String   @id @default(cuid())
  shop      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sizeCharts      SizeChart[]
  sizeAssignments SizeChartAssignment[]
  keywordRules    SizeKeywordRule[]
  purchaseSignals SizePurchaseSignal[]

  @@index([shop])
}

model SizeChart {
  id         String  @id @default(cuid())
  shopId     String
  title      String
  unit       String  @default("cm")
  columns    Json
  isDefault  Boolean @default(false)

  guideTitle     String?
  guideText      String?
  guideImage     String?
  showGuideImage Boolean @default(true)
  tips           String?
  disclaimer     String?

  shop               Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rows               SizeChartRow[]
  assigns            SizeChartAssignment[]
  keywordAssignments SizeKeywordRule[]
  purchaseSignals    SizePurchaseSignal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([shopId, isDefault])
}

model SizeChartRow {
  id        String @id @default(cuid())
  chartId   String
  label     String
  sortOrder Int    @default(0)
  values    Json

  chart SizeChart @relation(fields: [chartId], references: [id], onDelete: Cascade)

  @@index([chartId, sortOrder])
}

model SizeChartAssignment {
  id      String @id @default(cuid())
  shopId  String
  chartId String

  priority Int @default(100)

  // ALL | COLLECTION | TYPE | VENDOR | TAG | PRODUCT
  scope String

  // ALL        -> null
  // COLLECTION -> handle
  // TYPE       -> exact product type
  // VENDOR     -> exact vendor
  // TAG        -> exact tag
  // PRODUCT    -> gid://shopify/Product/123
  scopeValue String?

  enabled Boolean @default(true)

  shop  Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chart SizeChart @relation(fields: [chartId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, priority])
  @@index([shopId, scope, scopeValue])
}

model SizeKeywordRule {
  id       String  @id @default(cuid())
  shopId   String
  chartId  String
  keyword  String
  field    String  @default("ANY") // ANY | TITLE | HANDLE | TYPE | VENDOR | TAG
  priority Int     @default(500)
  enabled  Boolean @default(true)

  shop  Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chart SizeChart @relation(fields: [chartId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, enabled, priority])
  @@index([shopId, keyword])
}

model SizePurchaseSignal {
  id            String   @id @default(cuid())
  shopId        String
  chartId       String?
  productId     String?
  productHandle String?
  orderId       String?
  lineItemId    String?

  sizeLabel String
  heightCm  Float?
  weightKg  Float?

  kept     Boolean @default(true)
  returned Boolean @default(false)
  refunded Boolean @default(false)

  purchasedAt DateTime @default(now())

  shop  Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chart SizeChart? @relation(fields: [chartId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, productId])
  @@index([shopId, productHandle])
  @@index([shopId, chartId])
  @@index([shopId, kept])
  @@index([shopId, sizeLabel])
}