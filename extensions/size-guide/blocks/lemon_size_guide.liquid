<div data-lemon-size-root>
<button
  type="button"
  class="lemon-size__btn"
  data-lemon-size-trigger
  data-proxy-base="/apps/lemon-size/size-chart"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle | escape }}"
  data-collection-handles="{{ product.collections | map: 'handle' | join: ',' | escape }}"
  data-product-type="{{ product.type | escape }}"
  data-product-vendor="{{ product.vendor | escape }}"
  data-product-tags="{{ product.tags | join: ',' | escape }}"
  data-product-image="{{ product.featured_image | image_url: width: 1200 }}"
  data-guides-base="https://lemon-size.vercel.app"
  data-available-sizes="{%- assign first = true -%}{%- for variant in product.variants -%}{%- if variant.available -%}{%- assign size_value = blank -%}{%- for option in product.options_with_values -%}{%- assign option_name_down = option.name | downcase -%}{%- if option_name_down contains 'size' or option_name_down contains 'shoe' or option_name_down contains 'eu' or option_name_down contains 'eur' or option_name_down contains 'us' or option_name_down contains 'uk' -%}{%- assign option_index = forloop.index -%}{%- case option_index -%}{%- when 1 -%}{%- assign size_value = variant.option1 -%}{%- when 2 -%}{%- assign size_value = variant.option2 -%}{%- when 3 -%}{%- assign size_value = variant.option3 -%}{%- endcase -%}{%- break -%}{%- endif -%}{%- endfor -%}{%- if size_value == blank -%}{%- if product.options.size == 1 -%}{%- assign size_value = variant.option1 -%}{%- elsif product.options.size == 2 -%}{%- assign second_option_name = product.options[1] | downcase -%}{%- if second_option_name contains 'size' or second_option_name contains 'shoe' or second_option_name contains 'eu' or second_option_name contains 'eur' or second_option_name contains 'us' or second_option_name contains 'uk' -%}{%- assign size_value = variant.option2 -%}{%- endif -%}{%- elsif product.options.size == 3 -%}{%- assign third_option_name = product.options[2] | downcase -%}{%- if third_option_name contains 'size' or third_option_name contains 'shoe' or third_option_name contains 'eu' or third_option_name contains 'eur' or third_option_name contains 'us' or third_option_name contains 'uk' -%}{%- assign size_value = variant.option3 -%}{%- endif -%}{%- endif -%}{%- endif -%}{%- if size_value != blank -%}{%- unless first -%},{%- endunless -%}{{ size_value | strip | escape }}{%- assign first = false -%}{%- endif -%}{%- endif -%}{%- endfor -%}"
>
  {{ block.settings.button_label | default: 'Size guide' }}
</button>

  <div class="lemon-size__modal" hidden data-lemon-size-modal>
    <div class="lemon-size__overlay" data-lemon-size-close></div>

    <div class="lemon-size__dialog" role="dialog" aria-modal="true" aria-label="Size guide">
      <div class="lemon-size__header">
        <div class="lemon-size__headings">
          <div class="lemon-size__title" data-lemon-size-title>Size guide</div>
          <div class="lemon-size__sub" data-lemon-size-subtitle></div>
        </div>

        <div class="lemon-size__actions">
          <div class="lemon-size__unit" role="tablist" aria-label="Units">
            <button type="button" class="lemon-size__unitbtn" data-lemon-unit="in">INCHES</button>
            <button type="button" class="lemon-size__unitbtn" data-lemon-unit="cm">CM</button>
          </div>

          <button type="button" class="lemon-size__close" aria-label="Close" data-lemon-size-close>×</button>
        </div>
      </div>

      <div class="lemon-size__layout">
        <div class="lemon-size__left">
                  <img
            class="lemon-size__productimg"
            alt="{{ product.title | escape }}"
            loading="lazy"
            width="1200"
            height="1500"
            data-lemon-productimg
          />
        </div>

        <div class="lemon-size__right">
          <div class="lemon-size__chart" data-lemon-size-chart></div>


 <div class="lemon-size__measure">
  <div class="lemon-size__measureHead">
    <strong data-lemon-guide-title>How to measure</strong>
    <div class="lemon-size__measureText" data-lemon-guide-text></div>
  </div>

  <div class="lemon-size__guideImgWrap" data-lemon-guide-imgwrap>
          <img
            class="lemon-size__measureImg"
            alt="How to measure size guide"
            loading="lazy"
            width="900"
            height="900"
            data-lemon-guide-img
          />
  </div>
  <div class="lemon-size__mutedRow is-hidden">
    <div class="lemon-size__mutedLabel">Tips</div>
    <div class="lemon-size__mutedText" data-lemon-guide-tips></div>
  </div>
  <div class="lemon-size__mutedRow is-hidden">
    <div class="lemon-size__mutedLabel">Note</div>
    <div class="lemon-size__mutedText" data-lemon-guide-disclaimer></div>
  </div>
</div>
        </div>
      </div>
    </div>
  </div>
</div>

{{ 'lemon-size.css' | asset_url | stylesheet_tag }}
<script src="{{ 'lemon-size.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Lemon Size Guide",
  "target": "section",
  "templates": ["product"],
  "settings": [
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Size guide" }
  ]
}
{% endschema %}